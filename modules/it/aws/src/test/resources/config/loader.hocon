{
  "license": { "accept": true }

  "input": {
    "streamName": ${STREAM_GOOD}
    "appName": ${APP_NAME}
    "initialPosition": { "type": "TRIM_HORIZON" }
    "customEndpoint": ${LOCALSTACK_ENDPOINT}
    "dynamodbCustomEndpoint": ${LOCALSTACK_ENDPOINT}
    "cloudwatchCustomEndpoint": ${LOCALSTACK_ENDPOINT}
    "workerIdentifier": "it-worker"
  }

  "output": {
    "good": {
      "url": ${ES_URL}
      "index": "snowplow"
      "auth": { "type": "NoAuth" }
    }
    "bad": {
      "streamName": ${STREAM_BAD}
      "customEndpoint": ${LOCALSTACK_ENDPOINT}
    }
  }

  "purpose": ${PURPOSE}
}
